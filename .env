# ============================================================
# BARAQAH FOODPOOL — Master Environment Variables
# Copy to .env and adjust for your environment
# ============================================================

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=baraqah
POSTGRES_USER=baraqah
POSTGRES_PASSWORD=baraqah_secret_change_me

# --- MongoDB ---
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_DB=baraqah
MONGO_USER=baraqah
MONGO_PASSWORD=baraqah_mongo_secret
MONGO_URI=mongodb://baraqah:baraqah_mongo_secret@mongodb:27017/baraqah?authSource=admin

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0

# --- Node.js Backend ---
NODE_ENV=development
NODE_PORT=3000
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
BCRYPT_ROUNDS=12
PYTHON_ML_URL=http://backend-python:8000

# --- Python Backend ---
PYTHON_PORT=8000
LOG_LEVEL=info

# --- Nginx ---
NGINX_PORT=80

# --- CORS ---
CORS_ORIGINS=*

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# --- Check-in Geofence ---
CHECKIN_DEFAULT_RADIUS_METERS=200

# --- Chat ---
CHAT_MESSAGE_OVERFLOW_LIMIT=500
